@model MeuProjeto.Models.ImcViewModel

@{
    ViewData["Title"] = "Calculadora de IMC";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card p-4 shadow-sm">
        <h2 class="text-center mb-4">Calculadora de IMC</h2>

        <form asp-action="Calcular" method="post">
            
            <div class="mb-3">
                <label class="form-label">Peso (kg) - Ex: 75,5</label>
                <input asp-for="Peso" class="form-control" type="number" step="0.01" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Altura (m) - Ex: 1,70</label>
                <input asp-for="Altura" class="form-control" type="number" step="0.01" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Calcular IMC</button>
        </form>

        @if (Model != null && Model.ResultadoImc > 0)
        {
            <div class="alert alert-info mt-4 text-center" role="alert">
                <h4>Seu IMC é: <strong>@Model.ResultadoImc.Value.ToString("F2")</strong></h4>
                <p class="mb-0">Classificação: <strong>@Model.Classificacao</strong></p>
            </div>
        }
    </div>
</div>